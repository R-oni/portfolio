* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary: #ffffff;
    --primary-dark: #a0a0a0;
    --success: #4ade80;
    --bg-dark: #1a1a1a;
    --bg-darker: #0d0d0d;
    --card-bg: #252525;
    --border: #404040;
    --text: #e5e5e5;
    --text-muted: #a0a0a0;
    --text-dim: #717171;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #000000;
    color: var(--text);
    line-height: 1.6;
}

/* ===== DASHBOARD ===== */
.dashboard {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #000000;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* ===== SIGNATURE SECTION ===== */
.signature-section {
    padding: 2rem 1rem;
    text-align: center;
    background: #000000;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
}

/* Barras animadas dentro da signature-section */
.sig-bars {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: flex-end;
    gap: 0;
    height: 80px;
    pointer-events: none;
    opacity: 0.18;
}
.sig-bars span {
    flex: 1;
    min-width: 0;
    height: var(--h, 30px);
    background: linear-gradient(180deg, #9ca3af 0%, #4b5563 100%);
    border-radius: 2px 2px 0 0;
    transform-origin: bottom center;
    animation: sigBarPulse 2.8s ease-in-out var(--d, 0s) infinite;
}
@keyframes sigBarPulse {
    0%   { transform: scaleY(0.75); opacity: 0.7; }
    50%  { transform: scaleY(1.15); opacity: 1;   }
    100% { transform: scaleY(0.75); opacity: 0.7; }
}

.signature-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
}

.signature-img {
    width: 150px;
    height: 150px;
    object-fit: contain;
    display: block !important;
    animation: slideDown 0.6s ease-out;
}

.tagline {
    font-size: 1.71rem;
    color: var(--text);
    font-weight: 400;
    font-family: 'DM Serif Display', Georgia, serif;
    font-style: italic;
    margin: 0.5rem 0 0 0;
    letter-spacing: 0.6px;
}

.client-logo-box {
    min-height: 116px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.75rem;
}

.client-logo {
    max-width: 634px;
    max-height: 232px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: none;
    animation: slideDown 0.8s ease-out;
}

.gold-text {
    /* Efeito de reflexo apenas no texto */
    font-weight: 700;
    color: transparent;
    background-image: linear-gradient(90deg, #00ffe7 0%, #fff 50%, #00ffe7 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    animation: goldShine 2.2s linear infinite;
}

@keyframes goldShine {
    0% { background-position: 200% center; }
    50% { background-position: 50% center; }
    100% { background-position: -200% center; }
}

/* ===== HEADER ===== */
.header {
    padding: 1.5rem 1rem;
    background: transparent;
    color: var(--text);
    text-align: center;
    animation: none;
}

.header-info {
    font-size: 0.9rem;
    opacity: 0.85;
}

.last-update {
    font-size: 0.75rem;
    opacity: 0.8;
    margin: 0.25rem 0 0 0;
}

/* ===== MAIN ===== */
.main {
    flex: 1;
    padding: 1rem;
    max-width: 100%;
    overflow-x: hidden;
}

/* ===== KPI GRID ===== */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
}

@media (min-width: 1400px) {
    .kpi-grid {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }
}

.kpi-mini {
    background: linear-gradient(135deg, var(--card-bg), rgba(0, 0, 0, 0.7));
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
    text-align: center;
    transition: all 0.3s ease;
}

.kpi-mini:active {
    transform: scale(0.98);
}

.kpi-mini-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    font-weight: 600;
}

.kpi-mini-value {
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
}

.kpi-mini-change {
    font-size: 0.75rem;
    color: var(--success);
    font-weight: 600;
}

/* ===== SELECTOR ===== */
.selector-section {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.selector-section label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
}

.month-select {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: rgba(0, 0, 0, 0.1);
    color: var(--text);
    font-size: 0.9rem;
    cursor: pointer;
}

.month-select:focus {
    outline: none;
    border-color: var(--primary);
}

/* ===== CHARTS GRID ===== */
.charts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

@media (min-width: 1400px) {
    .charts-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

.chart-mini {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
    transition: all 0.3s ease;
}

.chart-mini h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 1rem;
    text-transform: uppercase;
}

.chart-mini canvas {
    max-width: 100%;
    height: auto;
}

/* ===== COMENTÁRIOS GERAIS ===== */
.comentarios-gerais {
    margin: 0 0 1.5rem;
}

.comentarios-texto {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #cbd5e1;
    font-style: italic;
    border-left: 3px solid #cbd5e1;
    padding-left: 0.75rem;
    line-height: 1.5;
}

/* ===== FOOTER ===== */
.footer {
    padding: 1.5rem 1rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
}

/* ===== ANIMATIONS ===== */
@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.fade-in {
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
}

/* ===== MOBILE FIRST RESPONSIVE ===== */
@media (max-width: 600px) {
    .main {
        padding: 0.75rem;
    }

    .kpi-grid {
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .kpi-mini {
        padding: 0.75rem;
    }

    .kpi-mini-value {
        font-size: 1.25rem;
    }

    .selector-section {
        flex-direction: column;
        align-items: stretch;
    }

    .selector-section label {
        width: 100%;
    }

    .month-select {
        width: 100%;
    }
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar {
    width: 6px;
}

::-webkit-scrollbar-track {
    background: var(--bg-dark);
}

::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--primary-dark);
}

/* ===== CHART CANVAS WRAPPER ===== */
.chart-canvas-wrapper {
    position: relative;
    width: 100%;
}

/* ===== LANDING PAGE ===== */
.landing {
    min-height: 100vh;
    background: #000000;
    position: relative;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* garantir que conteúdo fique acima da marca-d'água */
.landing > * {
    position: relative;
    z-index: 1;
}

/* Marca-d'água de barras sutis (animadas) */
.bg-bars {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.06;
    filter: blur(0.6px) saturate(0.6);
}
.bg-bars .bar {
    width: 10px;
    background: linear-gradient(180deg, #cbd5e1 0%, #94a3b8 100%);
    border-radius: 3px;
    display: inline-block;
    transform-origin: bottom center;
    animation: barPulse 3.2s ease-in-out infinite;
}
.bg-bars .b1 { height: 40px; animation-delay: 0s; }
.bg-bars .b2 { height: 60px; animation-delay: 0.15s; }
.bg-bars .b3 { height: 30px; animation-delay: 0.3s; }
.bg-bars .b4 { height: 80px; animation-delay: 0.45s; }
.bg-bars .b5 { height: 50px; animation-delay: 0.6s; }
.bg-bars .b6 { height: 35px; animation-delay: 0.75s; }
.bg-bars .b7 { height: 70px; animation-delay: 0.9s; }

@keyframes barPulse {
    0% { transform: scaleY(0.85); opacity: 0.9; }
    50% { transform: scaleY(1.15); opacity: 1; }
    100% { transform: scaleY(0.85); opacity: 0.9; }
}

.landing-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem;
    background: transparent;
}

.landing-logo {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin-bottom: 0.6rem;
    animation: slideDown 0.6s ease-out;
}

.landing-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.25rem;
    animation: fadeIn 0.8s ease-out 0.3s both;
}

.landing-subtitle {
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: var(--text-muted);
    max-width: 500px;
    line-height: 1.8;
    margin-bottom: 2rem;
    animation: fadeIn 0.8s ease-out 0.6s both;
}

.landing-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid var(--border);
    border-radius: 2rem;
    color: var(--text);
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    animation: fadeIn 0.8s ease-out 0.9s both;
}

.landing-btn .whatsapp-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    vertical-align: middle;
    margin-right: 0.6rem;
    filter: none;
}

.landing-btn:hover {
    border-color: #00ffe7;
    color: #00ffe7;
}

.landing-btn-gold {
    background: #00ffe7;
    color: #000;
    border-color: #00ffe7;
    font-weight: 600;
}

.landing-btn-gold:hover {
    background: #00e6d0;
    border-color: #00e6d0;
    color: #000;
}

.landing-section {
    padding: 4rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
}

.landing-alt {
    background: rgba(255, 255, 255, 0.02);
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--text);
    text-align: center;
    margin-bottom: 2.5rem;
}

.landing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
}

.landing-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
}

.landing-card:hover {
    border-color: #00ffe7;
    transform: translateY(-2px);
}

.landing-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
}

.landing-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
}

.landing-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
}

.landing-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    max-width: 700px;
}

.landing-tag {
    padding: 0.5rem 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 2rem;
    font-size: 0.9rem;
    color: var(--text);
    transition: all 0.3s ease;
}

.landing-tag:hover {
    border-color: #00ffe7;
}

.landing-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    text-align: center;
}

.landing-step {
    padding: 1.5rem;
}

.step-number {
    width: 48px;
    height: 48px;
    line-height: 48px;
    border-radius: 50%;
    background: #00ffe7;
    color: #000;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 auto 1rem;
}

.landing-step h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
}

.landing-step p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
}

.landing-cta {
    text-align: center;
    padding: 4rem 1.5rem;
    background: transparent;
}

.landing-cta h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
}

.landing-cta p {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 1.05rem;
}

.landing-footer {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
}

.landing-footer-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition: all 0.3s ease;
}

.landing-footer-link:hover {
    border-color: #00ffe7;
    color: #00ffe7;
}

/* Scroll fade animation */
.scroll-fade {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
}

.scroll-fade.visible {
    opacity: 1;
    transform: translateY(0);
}

